# Sepolia RPC (Alchemy or Infura recommended)
SEPOLIA_RPC_URL=https://1rpc.io/sepolia

# Deployer private key (WITH 0x prefix)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Etherscan API key (for contract verification). Use "dummy" if you only deploy and skip --verify
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY_OR_DUMMY

# ── Deployed Addresses (filled after deployment) ──
AUCTION_ADDRESS=
BLIND_POOL_ADDRESS=
TOKEN_ADDRESS=
